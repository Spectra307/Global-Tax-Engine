# Global Tax Engine - Backend Environment Variables
# Copy this file to .env and fill in your Supabase credentials.

# Your Supabase project URL (found in Project Settings > API)
SUPABASE_URL=https://your-project-ref.supabase.co

# Your Supabase anonymous/public key (found in Project Settings > API)
SUPABASE_ANON_KEY=your-anon-key-here

# Port for the Express server (default: 3001)
PORT=3001
